{
  "state": {
    "principal": 250000,
    "rate": 7.1,
    "years": 20,
    "fees": 1200
  },
  "derived": {
    "monthlyPayment": "payment(principal, rate, years)",
    "totalRepayment": "monthlyPayment * years * 12 + fees",
    "totalInterest": "totalRepayment - principal - fees",
    "interestShare": "(totalInterest / max(totalRepayment, 1)) * 100",
    "yearlyBreakdown": "amortization(principal, rate, years)"
  },
  "actions": {
    "resetScenario": [
      {
        "type": "set",
        "values": {
          "principal": 250000,
          "rate": 7.1,
          "years": 20,
          "fees": 1200
        }
      },
      {
        "type": "validate",
        "rules": [
          {
            "field": "principal",
            "test": "principal > 0",
            "message": "Principal must be greater than zero."
          },
          {
            "field": "rate",
            "test": "rate > 0",
            "message": "Rate must be greater than zero."
          },
          {
            "field": "years",
            "test": "years >= 1",
            "message": "Term must be at least one year."
          },
          {
            "field": "fees",
            "test": "fees >= 0",
            "message": "Fees cannot be negative."
          }
        ]
      }
    ],
    "requestQuote": [
      {
        "type": "validate",
        "rules": [
          {
            "field": "principal",
            "test": "principal >= 1000",
            "message": "Principal must be at least $1,000."
          },
          {
            "field": "rate",
            "test": "rate > 0 && rate <= 20",
            "message": "Rate must stay between 0 and 20."
          },
          {
            "field": "years",
            "test": "years >= 1 && years <= 30",
            "message": "Term must stay between 1 and 30 years."
          },
          {
            "field": "fees",
            "test": "fees >= 0",
            "message": "Fees cannot be negative."
          }
        ]
      },
      {
        "type": "log",
        "payload": {
          "principal": {
            "expr": "principal"
          },
          "rate": {
            "expr": "rate"
          },
          "years": {
            "expr": "years"
          },
          "monthlyPayment": {
            "expr": "monthlyPayment"
          },
          "totalInterest": {
            "expr": "totalInterest"
          }
        }
      },
      {
        "type": "alert",
        "message": "Projected payment: {{formatCurrency(monthlyPayment)}} each month."
      }
    ]
  },
  "ui": {
    "type": "Container",
    "props": {
      "variant": "page",
      "gap": "24px"
    },
    "children": [
      {
        "type": "Card",
        "props": {
          "tone": "hero"
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "as": "span",
              "tone": "eyebrow",
              "content": "Controlled React Runtime"
            }
          },
          {
            "type": "Text",
            "props": {
              "as": "h1",
              "tone": "display",
              "content": "Loan Studio"
            }
          },
          {
            "type": "Text",
            "props": {
              "tone": "lead",
              "content": "A schema-driven lending UI with declarative state, derived formulas, guarded actions, and a component registry."
            }
          }
        ]
      },
      {
        "type": "Container",
        "props": {
          "variant": "split",
          "gap": "20px"
        },
        "children": [
          {
            "type": "Card",
            "props": {
              "title": "Scenario inputs",
              "subtitle": "Bindings write into state while validation and actions stay declarative."
            },
            "children": [
              {
                "type": "NumberInput",
                "props": {
                  "label": "Principal",
                  "prefix": "$",
                  "value": {
                    "bind": "principal"
                  },
                  "min": 1000,
                  "step": 1000,
                  "hint": "Set the original loan amount.",
                  "error": {
                    "expr": "runtime.errors.principal"
                  }
                }
              },
              {
                "type": "Slider",
                "props": {
                  "label": "Interest rate",
                  "suffix": "%",
                  "value": {
                    "bind": "rate"
                  },
                  "min": 0.5,
                  "max": 15,
                  "step": 0.1,
                  "hint": "Adjust the annual interest rate.",
                  "error": {
                    "expr": "runtime.errors.rate"
                  }
                }
              },
              {
                "type": "Select",
                "props": {
                  "label": "Term",
                  "value": {
                    "bind": "years"
                  },
                  "options": [
                    {
                      "label": "10 years",
                      "value": 10
                    },
                    {
                      "label": "15 years",
                      "value": 15
                    },
                    {
                      "label": "20 years",
                      "value": 20
                    },
                    {
                      "label": "25 years",
                      "value": 25
                    },
                    {
                      "label": "30 years",
                      "value": 30
                    }
                  ],
                  "hint": "Select the repayment term.",
                  "error": {
                    "expr": "runtime.errors.years"
                  }
                }
              },
              {
                "type": "NumberInput",
                "props": {
                  "label": "Closing fees",
                  "prefix": "$",
                  "value": {
                    "bind": "fees"
                  },
                  "min": 0,
                  "step": 100,
                  "hint": "One-time costs included in the scenario.",
                  "error": {
                    "expr": "runtime.errors.fees"
                  }
                }
              },
              {
                "type": "Container",
                "props": {
                  "variant": "actions",
                  "gap": "12px"
                },
                "children": [
                  {
                    "type": "Button",
                    "props": {
                      "label": "Request quote",
                      "variant": "primary",
                      "onClick": {
                        "action": "requestQuote"
                      },
                      "disabled": {
                        "expr": "runtime.busyActions.requestQuote === true"
                      }
                    }
                  },
                  {
                    "type": "Button",
                    "props": {
                      "label": "Reset scenario",
                      "variant": "secondary",
                      "onClick": {
                        "action": "resetScenario"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "props": {
              "title": "Derived summary",
              "subtitle": "Values below are recalculated from state on every change."
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "tone": "metric",
                  "content": "{{formatCurrency(monthlyPayment)}}"
                }
              },
              {
                "type": "Text",
                "props": {
                  "tone": "caption",
                  "content": "Estimated monthly payment"
                }
              },
              {
                "type": "StatGrid",
                "props": {
                  "items": [
                    {
                      "label": "Total repayment",
                      "value": "{{formatCurrency(totalRepayment)}}"
                    },
                    {
                      "label": "Interest + fees",
                      "value": "{{formatCurrency(totalInterest + fees)}}"
                    },
                    {
                      "label": "Interest share",
                      "value": "{{round(interestShare, 1)}}%"
                    },
                    {
                      "label": "Term length",
                      "value": "{{years}} years"
                    }
                  ]
                }
              },
              {
                "type": "Text",
                "visibleWhen": "monthlyPayment > 2200",
                "props": {
                  "tone": "note",
                  "content": "This configuration pushes the monthly payment above the internal affordability threshold."
                }
              },
              {
                "type": "Text",
                "visibleWhen": "runtime.lastAction === 'requestQuote' && !hasErrors(runtime.errors)",
                "props": {
                  "tone": "success",
                  "content": "Validation passed. The runtime accepted the quote request flow."
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "props": {
          "title": "Yearly payoff profile",
          "subtitle": "A complex component can stay in the registry while JSON only names the component and its bindings."
        },
        "children": [
          {
            "type": "BarChart",
            "props": {
              "data": {
                "expr": "yearlyBreakdown"
              },
              "labelKey": "year",
              "maxBars": 12,
              "bars": [
                {
                  "key": "principalPaid",
                  "label": "Principal",
                  "color": "#0f766e"
                },
                {
                  "key": "interestPaid",
                  "label": "Interest",
                  "color": "#f97316"
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
